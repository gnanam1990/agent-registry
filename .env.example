# Arc testnet deploy config — verified against arcpayments/NETWORK.md (see NETWORK.md here).
# TESTNET ONLY. Never commit a real .env or a private key. No mainnet in v1.

# ---- Network ----
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app

# ---- USDC (ERC-20, 6 decimals) ----
# Passed to contracts as a CONSTRUCTOR ARG by the deploy script — never hardcoded in a
# contract. USDC on Arc is 6 decimals; do not assume 18.
USDC_ADDRESS=0x3600000000000000000000000000000000000000
USDC_DECIMALS=6

# ---- Explorer verification (Arc testnet = Blockscout; API key optional) ----
ARC_VERIFIER_URL=https://testnet.arcscan.app/api/

# ---- Keys (fill locally; NEVER commit, NEVER print) ----
# Deployer = agent A / payer / attester in the smoke. Must hold Arc-testnet gas
# (native USDC) and, for the escrow smoke, >= SMOKE_AMOUNT test USDC (ERC-20).
DEPLOYER_PRIVATE_KEY=
# A second funded agent (agent B / payee / subject) for the smoke. Needs gas only.
AGENT_B_PRIVATE_KEY=

# ---- Deployed addresses (filled after `forge script script/Deploy.s.sol --broadcast`) ----
REGISTRY_ADDRESS=
ATTESTATIONS_ADDRESS=
ESCROW_ADDRESS=

# ---- Smoke (optional) ----
# Escrow amount in USDC base units (6 decimals). Default 1_000_000 = $1.00.
SMOKE_AMOUNT=1000000
